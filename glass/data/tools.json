{
  "domain": "EXEC",
  "visual_class": "neon-red",
  "manifest": {
    "0": {
      "name": "ctxdump",
      "shortcut": "X0",
      "icon": "scan-text",
      "description": "AI context orchestrator. Extracts a zero-ambiguity, secret-scrubbed, semantically ordered dump of any repository for LLM ingestion.",
      "target": "Arch / Debian",
      "repo_url": "https://git.trap.lol/trap/payloads/src/branch/main/backend-only/dir-context-gen",
      "install_cmd": "curl -fsSL https://git.trap.lol/trap/payloads/src/branch/main/backend-only/dir-context-gen/setup_ctxdump.sh > /tmp/setup_ctx.sh && bash /tmp/setup_ctx.sh && rm /tmp/setup_ctx.sh"
    },
    "1": {
      "name": "wbc",
      "shortcut": "X1",
      "icon": "archive",
      "description": "Submits URLs to the Wayback Machine and tracks job status with atomic local state.",
      "target": "Arch / Debian",
      "repo_url": "https://git.trap.lol/trap/payloads/src/branch/main/backend-only/web-archive",
      "install_cmd": "curl -fsSL https://git.trap.lol/trap/payloads/src/branch/main/backend-only/web-archive/setup_wbc.sh > /tmp/setup_wbc.sh && bash /tmp/setup_wbc.sh && rm /tmp/setup_wbc.sh"
    },
    "2": {
      "name": "OIDC-Bridge",
      "shortcut": "X2",
      "icon": "refrigerator",
      "description": "A lightweight, sovereign, standalone OpenID Connect (OIDC) provider bridge.",
      "target": "Arch / Debian",
      "repo_url": "https://git.trap.lol/trap/payloads/src/branch/main/backend-only/oidc-bridge",
      "install_cmd": "git clone https://git.trap.lol/trap/oidc-bridge.git"
    }
  }
}