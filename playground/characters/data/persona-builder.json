    {
      "id": "personality",
      "label": "Personality",
      "icon": "brain",
      "multi": true,
      "options": ["Cold & calculating", "Warm & empathetic", "Witty / dry humour", "Impulsive", "Cautious", "Idealistic", "Cynical", "Loyal", "Secretive", "Chaotic"]
    },
    {
      "id": "motivation",
      "label": "Primary drive",
      "icon": "target",
      "options": ["Survival", "Power", "Revenge", "Belonging", "Knowledge", "Freedom", "Redemption", "Wealth", "Love", "Duty"]
    },
    {
      "id": "tone",
      "label": "Tone they carry",
      "icon": "mic",
      "options": ["Quiet & reserved", "Blunt & direct", "Charming & disarming", "Unsettling / unpredictable", "Noble & formal", "Street-smart & casual", "Intellectual & verbose"]
    }
